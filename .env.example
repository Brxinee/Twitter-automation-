# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# X (Twitter) API credentials — OAuth 1.0a
# Create your app at https://developer.twitter.com
# IMPORTANT: set app permission to "Read and Write", then regenerate access tokens.
X_API_KEY=your_x_app_api_key
X_API_SECRET=your_x_app_api_secret
X_ACCESS_TOKEN=your_x_access_token_for_smell0ff
X_ACCESS_SECRET=your_x_access_token_secret_for_smell0ff

# Random secret to protect the cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=replace_with_a_random_secret_string
